# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Feature flags
FEATURE_META_INTEGRATION=true
FEATURE_GOOGLE_INTEGRATION=true
FEATURE_GOOGLE_GMAIL=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth security (generate: openssl rand -base64 32)
OAUTH_STATE_SECRET=replace-with-32-byte-secret
INTEGRATION_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Meta
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/meta/callback

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# Sentry
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
GOOGLE_WEBHOOK_CHANNEL_TOKEN=

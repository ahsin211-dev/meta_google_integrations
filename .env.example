# App
APP_URL=http://localhost:3000
NODE_ENV=development

# Dev-only: allow x-workspace-id + x-user-id headers without Supabase JWT
INTEGRATION_DEV_AUTH=false

# Feature flags
INTEGRATIONS_META_ENABLED=true
INTEGRATIONS_GOOGLE_ENABLED=true
GOOGLE_ENABLE_GMAIL=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Token encryption (32-byte base64: openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=

# Meta
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/integrations/meta/callback
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v21.0
META_OAUTH_USE_PKCE=true
META_SCOPES=pages_show_list,pages_read_engagement,instagram_basic

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
GOOGLE_SCOPES=openid,email,profile,https://www.googleapis.com/auth/calendar

# Sentry
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DSN=
